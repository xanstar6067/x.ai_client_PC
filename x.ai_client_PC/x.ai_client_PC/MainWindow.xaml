<Window x:Class="x.ai_client_PC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="xAI Grok Chat PC"
        Height="820"
        Width="1280"
        MinHeight="700"
        MinWidth="1080"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="330" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="xAI Grok Chat"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="CredentialStatusText"
                               Margin="0,4,0,12"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="API-ключ не сохранён" />
                </StackPanel>

                <UniformGrid Grid.Row="1"
                             Columns="1"
                             Margin="0,0,0,12">
                    <Button x:Name="TextSectionButton" Content="Текст" Tag="Text" Click="SectionButton_Click" />
                    <Button x:Name="ImagesSectionButton" Content="Изображения" Tag="Images" Click="SectionButton_Click" />
                    <Button x:Name="VideosSectionButton" Content="Видео" Tag="Videos" Click="SectionButton_Click" />
                    <Button x:Name="ModelsSectionButton" Content="Модели" Tag="Models" Click="SectionButton_Click" />
                    <Button x:Name="SettingsSectionButton" Content="Настройки" Tag="Settings" Click="SectionButton_Click" />
                </UniformGrid>

                <TextBox Grid.Row="2"
                         x:Name="SearchBox"
                         Margin="0,0,0,10"
                         ToolTip="Поиск по текущему списку"
                         TextChanged="SearchBox_TextChanged" />

                <ListBox Grid.Row="3"
                         x:Name="ConversationList"
                         SelectionChanged="ConversationList_SelectionChanged" />

                <WrapPanel Grid.Row="4" Margin="0,12,0,0">
                    <Button x:Name="NewConversationButton" Content="+ Новый" Click="NewConversationButton_Click" />
                    <Button x:Name="DuplicateConversationButton" Content="Копия" Click="DuplicateConversationButton_Click" />
                    <Button x:Name="DeleteConversationButton" Content="Удалить" Style="{StaticResource DangerButton}" Click="DeleteConversationButton_Click" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="14,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="310" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="SectionTitle"
                                   Text="Текст"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="SectionSubtitle"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="Диалог через Responses API" />
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                              x:Name="ActiveModelCombo"
                              Margin="12,0,8,0"
                              SelectionChanged="ActiveModelCombo_SelectionChanged" />
                    <Button Grid.Column="2"
                            x:Name="RefreshModelsButton"
                            Content="Обновить"
                            Click="RefreshModelsButton_Click" />
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid x:Name="TextView">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <ScrollViewer x:Name="MessageScroll"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="MessagePanel" />
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ListBox Grid.Row="0"
                                     x:Name="AttachmentList"
                                     MinHeight="0"
                                     MaxHeight="70"
                                     Margin="0,0,0,8" />
                            <TextBox Grid.Row="1"
                                     x:Name="PromptBox"
                                     MinHeight="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     PreviewKeyDown="PromptBox_PreviewKeyDown" />
                            <DockPanel Grid.Row="2" Margin="0,10,0,0">
                                <TextBlock DockPanel.Dock="Left"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="Enter отправляет, Shift+Enter новая строка" />
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button x:Name="AttachButton" Content="Прикрепить" Click="AttachButton_Click" />
                                    <Button x:Name="ClearAttachmentsButton" Content="Очистить" Click="ClearAttachmentsButton_Click" />
                                    <Button x:Name="StopButton" Content="Стоп" IsEnabled="False" Click="StopButton_Click" />
                                    <Button x:Name="SendButton" Content="Отправить" Style="{StaticResource PrimaryButton}" Click="SendButton_Click" />
                                </StackPanel>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="ImagesView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Промпт" FontWeight="SemiBold" />
                            <TextBox Grid.Row="1"
                                     x:Name="ImagePromptBox"
                                     MinHeight="76"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                            <DockPanel Grid.Row="2" Margin="0,10,0,0">
                                <TextBox x:Name="ImageSourceBox"
                                         DockPanel.Dock="Left"
                                         MinWidth="260"
                                         ToolTip="URL или локальный файл для image edit"
                                         Margin="0,0,8,0" />
                                <Button Content="Выбрать" Click="ChooseImageSourceButton_Click" />
                                <Button x:Name="GenerateImageButton" Content="Сгенерировать" Style="{StaticResource PrimaryButton}" Click="GenerateImageButton_Click" />
                                <Button x:Name="SaveImageButton" Content="Сохранить" IsEnabled="False" Click="SaveImageButton_Click" />
                            </DockPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="280" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Image x:Name="GeneratedImagePreview"
                                       Stretch="Uniform" />
                                <TextBlock Grid.Row="1"
                                           x:Name="ImageResultText"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="Результат появится здесь." />
                            </Grid>
                        </Border>
                        <Border Grid.Column="1"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="12,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="История" FontWeight="SemiBold" />
                                <ListBox Grid.Row="1"
                                         x:Name="ImageHistoryList"
                                         Margin="0,8,0,0"
                                         SelectionChanged="ImageHistoryList_SelectionChanged" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="VideosView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Промпт" FontWeight="SemiBold" />
                            <TextBox Grid.Row="1"
                                     x:Name="VideoPromptBox"
                                     MinHeight="76"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                            <DockPanel Grid.Row="2" Margin="0,10,0,0">
                                <TextBox x:Name="VideoSourceBox"
                                         DockPanel.Dock="Left"
                                         MinWidth="260"
                                         ToolTip="URL или локальное изображение для image-to-video"
                                         Margin="0,0,8,0" />
                                <Button Content="Выбрать" Click="ChooseVideoSourceButton_Click" />
                                <Button x:Name="GenerateVideoButton" Content="Сгенерировать" Style="{StaticResource PrimaryButton}" Click="GenerateVideoButton_Click" />
                                <Button x:Name="PollVideoButton" Content="Проверить" IsEnabled="False" Click="PollVideoButton_Click" />
                                <Button x:Name="SaveVideoButton" Content="Сохранить" IsEnabled="False" Click="SaveVideoButton_Click" />
                            </DockPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="280" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <MediaElement x:Name="VideoPlayer"
                                              LoadedBehavior="Manual"
                                              UnloadedBehavior="Manual"
                                              Stretch="Uniform" />
                                <DockPanel Grid.Row="1" Margin="0,10,0,0">
                                    <TextBlock x:Name="VideoStatusText"
                                               DockPanel.Dock="Left"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Статус видео появится здесь." />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button x:Name="PlayVideoButton" Content="Пуск" IsEnabled="False" Click="PlayVideoButton_Click" />
                                        <Button x:Name="PauseVideoButton" Content="Пауза" IsEnabled="False" Click="PauseVideoButton_Click" />
                                    </StackPanel>
                                </DockPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="12,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="История" FontWeight="SemiBold" />
                                <ListBox Grid.Row="1"
                                         x:Name="VideoHistoryList"
                                         Margin="0,8,0,0"
                                         SelectionChanged="VideoHistoryList_SelectionChanged" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="ModelsView" Visibility="Collapsed">
                    <Border Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="ModelsStatusText"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Модели ещё не загружены." />
                            <ListView Grid.Row="1"
                                      x:Name="ModelsList"
                                      Margin="0,10,0,0">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="ID" Width="220" DisplayMemberBinding="{Binding Id}" />
                                        <GridViewColumn Header="Тип" Width="80" DisplayMemberBinding="{Binding Kind}" />
                                        <GridViewColumn Header="Версия" Width="90" DisplayMemberBinding="{Binding Version}" />
                                        <GridViewColumn Header="Модальности" Width="180" DisplayMemberBinding="{Binding Summary}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>

                <ScrollViewer x:Name="SettingsView"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <Border Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="API" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="Ключ сохраняется в Windows Credential Manager и не попадает в резервную копию."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,2,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox Grid.Column="0"
                                             x:Name="ApiKeyBox"
                                             ToolTip="xAI API-ключ" />
                                <TextBox Grid.Column="0"
                                         x:Name="ApiKeyRevealBox"
                                         Visibility="Collapsed"
                                         ToolTip="xAI API-ключ" />
                                <Button Grid.Column="1"
                                        x:Name="ToggleApiKeyVisibilityButton"
                                        Content="👁"
                                        ToolTip="Показать или скрыть API-ключ"
                                        MinWidth="40"
                                        Margin="8,0,0,0"
                                        Click="ToggleApiKeyVisibilityButton_Click" />
                            </Grid>
                            <WrapPanel Margin="0,10,0,16">
                                <Button Content="Сохранить ключ" Style="{StaticResource PrimaryButton}" Click="SaveApiKeyButton_Click" />
                                <Button Content="Удалить ключ" Style="{StaticResource DangerButton}" Click="DeleteApiKeyButton_Click" />
                                <Button Content="Загрузить модели" Click="RefreshModelsButton_Click" />
                            </WrapPanel>

                            <TextBlock Text="Базовый URL" FontWeight="SemiBold" />
                            <TextBox x:Name="BaseUrlBox" Margin="0,4,0,12" />

                            <TextBlock Text="Системная роль" FontWeight="SemiBold" />
                            <TextBox x:Name="SystemPromptBox"
                                     MinHeight="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,4,0,12" />

                            <TextBlock Text="Резервная копия" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="Экспорт не содержит API-ключ."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,2,0,8" />
                            <WrapPanel>
                                <Button Content="Экспорт" Click="ExportBackupButton_Click" />
                                <Button Content="Импорт" Click="ImportBackupButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Border Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Параметры"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="CompatibilityText"
                               Text="Выберите модель."
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,14" />

                    <TextBlock Text="Текст" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock x:Name="ReasoningEffortLabel" Text="Усилие рассуждения" Margin="0,8,0,2" />
                    <ComboBox x:Name="ReasoningEffortCombo" SelectionChanged="SettingsControl_Changed">
                        <ComboBoxItem Content="none" />
                        <ComboBoxItem Content="low" />
                        <ComboBoxItem Content="medium" />
                        <ComboBoxItem Content="high" />
                        <ComboBoxItem Content="xhigh" />
                    </ComboBox>
                    <TextBlock x:Name="TemperatureLabel" Text="Температура" Margin="0,8,0,2" />
                    <TextBox x:Name="TemperatureBox" TextChanged="SettingsControl_Changed" />
                    <TextBlock x:Name="TopPLabel" Text="Top P" Margin="0,8,0,2" />
                    <TextBox x:Name="TopPBox" TextChanged="SettingsControl_Changed" />
                    <TextBlock x:Name="MaxTokensLabel" Text="Макс. токенов ответа, 0 = авто" Margin="0,8,0,2" />
                    <TextBox x:Name="MaxTokensBox" TextChanged="SettingsControl_Changed" />
                    <TextBlock x:Name="FrequencyPenaltyLabel" Text="Штраф за частоту" Margin="0,8,0,2" />
                    <TextBox x:Name="FrequencyPenaltyBox" TextChanged="SettingsControl_Changed" />
                    <TextBlock x:Name="PresencePenaltyLabel" Text="Штраф за присутствие" Margin="0,8,0,2" />
                    <TextBox x:Name="PresencePenaltyBox" TextChanged="SettingsControl_Changed" />
                    <TextBlock Text="Сообщений в контексте" Margin="0,8,0,2" />
                    <TextBox x:Name="ContextLimitBox" TextChanged="SettingsControl_Changed" />

                    <CheckBox x:Name="WebSearchCheck" Content="Поиск в вебе" Margin="0,10,0,0" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                    <CheckBox x:Name="XSearchCheck" Content="Поиск в X" Margin="0,6,0,0" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                    <CheckBox x:Name="UsePreviousResponseCheck" Content="Использовать previousResponseId" Margin="0,6,0,0" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />
                    <CheckBox x:Name="StoreServerResponsesCheck" Content="Хранить ответы на сервере" Margin="0,6,0,16" Checked="SettingsControl_Changed" Unchecked="SettingsControl_Changed" />

                    <Separator />
                    <TextBlock Text="Изображения" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,0" />
                    <TextBlock Text="Соотношение сторон" Margin="0,8,0,2" />
                    <ComboBox x:Name="ImageAspectCombo" SelectionChanged="SettingsControl_Changed">
                        <ComboBoxItem Content="auto" />
                        <ComboBoxItem Content="1:1" />
                        <ComboBoxItem Content="16:9" />
                        <ComboBoxItem Content="9:16" />
                        <ComboBoxItem Content="4:3" />
                        <ComboBoxItem Content="3:4" />
                        <ComboBoxItem Content="3:2" />
                        <ComboBoxItem Content="2:3" />
                        <ComboBoxItem Content="2:1" />
                        <ComboBoxItem Content="1:2" />
                    </ComboBox>
                    <TextBlock Text="Разрешение" Margin="0,8,0,2" />
                    <ComboBox x:Name="ImageResolutionCombo" SelectionChanged="SettingsControl_Changed">
                        <ComboBoxItem Content="1k" />
                        <ComboBoxItem Content="2k" />
                    </ComboBox>
                    <TextBlock Text="Количество" Margin="0,8,0,2" />
                    <TextBox x:Name="ImageCountBox" TextChanged="SettingsControl_Changed" />

                    <Separator Margin="0,16,0,0" />
                    <TextBlock Text="Видео" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,0" />
                    <TextBlock Text="Соотношение сторон" Margin="0,8,0,2" />
                    <ComboBox x:Name="VideoAspectCombo" SelectionChanged="SettingsControl_Changed">
                        <ComboBoxItem Content="16:9" />
                        <ComboBoxItem Content="9:16" />
                        <ComboBoxItem Content="1:1" />
                        <ComboBoxItem Content="4:3" />
                        <ComboBoxItem Content="3:4" />
                        <ComboBoxItem Content="3:2" />
                        <ComboBoxItem Content="2:3" />
                    </ComboBox>
                    <TextBlock Text="Разрешение" Margin="0,8,0,2" />
                    <ComboBox x:Name="VideoResolutionCombo" SelectionChanged="SettingsControl_Changed">
                        <ComboBoxItem Content="480p" />
                        <ComboBoxItem Content="720p" />
                    </ComboBox>
                    <TextBlock Text="Длительность, 1-15 сек." Margin="0,8,0,2" />
                    <TextBox x:Name="VideoDurationBox" TextChanged="SettingsControl_Changed" />

                    <Separator Margin="0,16,0,0" />
                    <TextBlock Text="Использование" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,0" />
                    <TextBlock x:Name="UsageText"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Токены и стоимость появятся после ответа." />
                    <TextBlock x:Name="LastResponseIdText"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
