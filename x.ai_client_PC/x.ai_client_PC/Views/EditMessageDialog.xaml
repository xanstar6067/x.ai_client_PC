<Window x:Class="x.ai_client_PC.Views.EditMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit message" Height="300" Width="500" WindowStartupLocation="CenterOwner"
        Background="#161B22" Foreground="#E8EAED">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="12,6" Margin="0,0,8,0" />
            <Button Content="Save" IsDefault="True" Click="Save_Click" Padding="12,6" />
        </StackPanel>
        <TextBox x:Name="EditBox" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />
    </DockPanel>
</Window>